# Meta Embedded Signup (WhatsApp / Messenger channels)
VITE_META_CONFIG_ID=your_facebook_login_for_business_config_id

# Instagram OAuth 2.0 (Instagram API with Instagram Login)
# VITE_INSTAGRAM_APP_ID  — same as your Meta App ID (used as OAuth client_id)
# VITE_IG_REDIRECT_URI   — must match IG_OAUTH_REDIRECT_URI in backend/.env exactly
#                          Points to the backend callback, e.g.:
#                          https://xxxx.ngrok-free.app/integrations/instagram/oauth-callback
VITE_INSTAGRAM_APP_ID=your_meta_app_id
VITE_IG_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/integrations/instagram/oauth-callback

# Business context (demo value for local dev)
VITE_BUSINESS_ID=demo-business-001

# Firebase Web SDK
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
