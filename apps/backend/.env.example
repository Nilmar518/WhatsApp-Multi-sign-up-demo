PORT=3001

# ─── Non-sensitive configuration (safe for .env) ─────────────────────────────

# Webhook (Meta / WhatsApp)
NGROK_URL=https://your-ngrok-url.ngrok-free.app
META_WEBHOOK_VERIFY_TOKEN=migo_verify_secret_2024

# Channex Webhook (Airbnb / PMS channel events)
# Public base URL for inbound Channex webhook callbacks (non-sensitive — deployment config).
# Webhook registered at: {CHANNEX_WEBHOOK_CALLBACK_URL}/channex/webhooks
# Dev: use your ngrok URL  Prod: your public API domain
CHANNEX_WEBHOOK_CALLBACK_URL=https://your-ngrok-or-prod-url.example.com

# Instagram OAuth 2.0 (Instagram API with Instagram Login)
# IG_OAUTH_REDIRECT_URI must match exactly what is registered in Meta App Dashboard.
# In dev: use your ngrok URL — e.g. https://xxxx.ngrok-free.app/integrations/instagram/oauth-callback
# In prod: your public API domain
# URL the backend redirects the browser to after a successful OAuth callback.
# In dev: the Vite frontend (self-signed TLS)
IG_OAUTH_REDIRECT_URI=
FRONTEND_URL=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# Firebase project identifiers (non-sensitive)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project_id.iam.gserviceaccount.com

# ─── Sensitive secrets (prefer .env.secrets — see .env.secrets.example) ──────
# These fallback values are read by SecretManagerService if .env.secrets is absent.

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# System User Token escalation (optional — enables permanent tokens)
META_BUSINESS_ID=your_business_manager_id
META_SYSTEM_USER_ID=your_system_user_id
