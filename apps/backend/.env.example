PORT=3001

# ─── Non-sensitive configuration (safe for .env) ─────────────────────────────

# Webhook
NGROK_URL=https://your-ngrok-url.ngrok-free.app
META_WEBHOOK_VERIFY_TOKEN=migo_verify_secret_2024

# Firebase project identifiers (non-sensitive)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project_id.iam.gserviceaccount.com

# ─── Sensitive secrets (prefer .env.secrets — see .env.secrets.example) ──────
# These fallback values are read by SecretManagerService if .env.secrets is absent.

META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# System User Token escalation (optional — enables permanent tokens)
META_BUSINESS_ID=your_business_manager_id
META_SYSTEM_USER_ID=your_system_user_id
