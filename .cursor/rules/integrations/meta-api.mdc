### Dynamic ngrok URL — Webhook Verification

During local development, ngrok provides a dynamic HTTPS URL. The backend must read this from an environment variable rather than hardcoding it.

```typescript
// src/webhook/webhook.controller.ts
import { Controller, Get, Query, Res, Logger } from '@nestjs/common';
import { ConfigService } from '@nestjs/config';
import { Response } from 'express';

@Controller('webhook')
export class WebhookController {
  private readonly logger = new Logger(WebhookController.name);

  constructor(private config: ConfigService) {}

  @Get()
  verify(
    @Query('hub.mode') mode: string,
    @Query('hub.verify_token') token: string,
    @Query('hub.challenge') challenge: string,
    @Res() res: Response,
  ) {
    // Injected at runtime from NGROK_URL env var
    const ngrokUrl = this.config.get<string>('NGROK_URL');
    const verifyToken = this.config.get<string>('META_WEBHOOK_VERIFY_TOKEN');

    this.logger.log(`[WEBHOOK_VERIFY] mode=${mode} | active ngrok=${ngrokUrl}`);

    if (mode === 'subscribe' && token === verifyToken) {
      this.logger.log('[WEBHOOK_VERIFY] ✓ Verification successful');
      res.status(200).send(challenge);
    } else {
      this.logger.warn('[WEBHOOK_VERIFY] ✗ Token mismatch — rejected');
      res.status(403).send('Forbidden');
    }
  }
}
```

**Environment setup for dynamic ngrok:**

```bash
# .env (update each time ngrok restarts)
NGROK_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app
META_WEBHOOK_VERIFY_TOKEN=migo_verify_secret_2024

# After updating NGROK_URL, re-register the webhook in Meta Dashboard:
# App Dashboard → WhatsApp → Configuration → Webhook URL → {NGROK_URL}/webhook
```

> **Tip:** Use the `ngrok` Node.js SDK or a shell script to auto-update `NGROK_URL` and re-register the webhook via `PATCH /{WABA_ID}/subscribed_apps` on startup.
