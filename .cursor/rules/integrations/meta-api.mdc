# Meta API Management

## Core Rules

- **Rule:** Handle Meta's token lifecycle (Short-lived → Long-lived → System User exchange).
- **Requirement:** Define explicit error handling for single-use tokens and expiry (Error 100/190).
- **Infrastructure:** ngrok must be used for local webhook verification; ensure the logic supports dynamic ngrok URLs.
- **Versioning:** Always pin Graph API version (use `v19.0` or higher). Never use the unversioned alias.

---

## Networking Examples

### Defensive Wrapper — Axios Client for Meta Endpoints

Every call to the Meta Graph API **must** go through this wrapper. It logs `[REQUEST]`, `[RESPONSE]`, `[LATENCY]`, and `[ERROR_CODE]` for observability.

```typescript
// src/common/logger/defensive-logger.service.ts
import { Injectable, Logger } from '@nestjs/common';
import axios, { AxiosRequestConfig, AxiosResponse } from 'axios';

@Injectable()
export class DefensiveLoggerService {
  private readonly logger = new Logger('MetaAPI');

  async request<T>(config: AxiosRequestConfig): Promise<T> {
    const start = Date.now();
    const url = String(config.url ?? '');

    this.logger.log(`[REQUEST] ${config.method?.toUpperCase()} ${url}`);
    if (config.data) {
      this.logger.debug(`[REQUEST_BODY] ${JSON.stringify(config.data)}`);
    }

    try {
      const response: AxiosResponse<T> = await axios({ ...config });
      const latency = Date.now() - start;

      this.logger.log(`[RESPONSE] ${response.status} | [LATENCY] ${latency}ms`);
      this.logger.debug(`[RESPONSE_BODY] ${JSON.stringify(response.data)}`);

      return response.data;
    } catch (err: any) {
      const latency = Date.now() - start;
      const errorCode = err?.response?.data?.error?.code;
      const errorMessage = err?.response?.data?.error?.message;

      this.logger.error(
        `[ERROR_CODE] ${errorCode ?? 'UNKNOWN'} | [LATENCY] ${latency}ms | ${errorMessage ?? err.message}`,
      );

      // Handle single-use / expired token — see Token Error Handling below
      if (errorCode === 100 || errorCode === 190) {
        throw new TokenExpiredError(
          `Meta token error (${errorCode}): ${errorMessage}`,
          errorCode,
        );
      }

      throw err;
    }
  }
}

export class TokenExpiredError extends Error {
  constructor(message: string, public readonly metaErrorCode: number) {
    super(message);
    this.name = 'TokenExpiredError';
  }
}
```

